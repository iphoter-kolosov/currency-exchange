{
  "name": "@currency-exchange/bot",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-env --env-file=.env --unstable-kv src/main.ts",
    "start": "deno run --allow-net --allow-env --unstable-kv src/main.ts",
    "check": "deno check src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "grammy": "https://deno.land/x/grammy@v1.30.0/mod.ts",
    "grammy/types": "https://deno.land/x/grammy@v1.30.0/types.ts",
    "std/": "https://deno.land/std@0.224.0/"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": true,
    "useTabs": false
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"],
    "strict": true
  }
}
